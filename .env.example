# =========================================================================
#             MODELLPORTFÖLJEN ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# =========================================================================
# Kopiera denna fil till '.env' och fyll i dina faktiska uppgifter.

# 1. SYSTEM INSTÄLLNINGAR
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"

# 2. GEMINI AI API (INTEGRITY SECRETS)
GEMINI_API_KEY=""

# 3. STRIPE API NYCKLAR (Developers -> API Keys)
STRIPE_SECRET_KEY="sk_te"

# 4. STRIPE PRIS / PRODUKT-ID (Products -> Price ID / Product ID)
STRIPE_PRICE_SMALL="price_..."
STRIPE_PRICE_MID="price_..."
STRIPE_PRICE_LARGE="price_..."
